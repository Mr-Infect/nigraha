# NASA EarthData / FIRMS API Key (Used for live thermal / fire anomaly overlays)
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=your_nasa_firms_key_here

# GDELT Event Stream (Currently open, no key required, but placeholder for rate limits)
GDELT_API_KEY=your_gdelt_api_key_here

# Telegram API for OSINT scraper (Feature 28)
# Create an app at https://my.telegram.org/apps
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here

# AISStream API Key for live global maritime traffic (Feature 19)
# Register at https://aisstream.io/
AISSTREAM_API_KEY=your_aisstream_api_key_here
